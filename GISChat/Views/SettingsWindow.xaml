<Window x:Class="GISChat.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GIS Chat Settings"
        Width="520" Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="GIS Chat Settings" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>

        <!-- Provider -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="AI Provider:" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <ComboBox x:Name="ProviderCombo" Padding="4" SelectionChanged="Provider_Changed"/>
        </StackPanel>

        <!-- API Key -->
        <StackPanel Grid.Row="2" x:Name="ApiKeyPanel" Margin="0,0,0,10">
            <TextBlock Text="API Key:" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <PasswordBox x:Name="ApiKeyBox" MaxLength="200" Padding="4"/>
            <TextBlock x:Name="ApiKeyHelp" FontSize="10" Foreground="Gray" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Model with Refresh button -->
        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <TextBlock Text="Model:" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0" x:Name="ModelCombo" Padding="4" IsEditable="True"/>
                <Button Grid.Column="1" x:Name="RefreshModelsBtn" Content="Fetch Models"
                        Margin="6,0,0,0" Padding="10,4" Click="RefreshModels_Click"/>
            </Grid>
            <TextBlock x:Name="ModelStatus" FontSize="10" Foreground="Gray" Margin="0,2,0,0"
                       Text="Click 'Fetch Models' to load available models from the API"/>
        </StackPanel>

        <!-- Endpoint -->
        <StackPanel Grid.Row="4" x:Name="EndpointPanel" Margin="0,0,0,10">
            <TextBlock Text="API Endpoint (leave blank for default):" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox x:Name="EndpointBox" Padding="4"/>
            <TextBlock x:Name="EndpointHelp" FontSize="10" Foreground="Gray" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Checkboxes -->
        <CheckBox Grid.Row="5" x:Name="ConfirmCheck" Content="Ask for confirmation before executing code"
                  Margin="0,0,0,6" IsChecked="True"/>
        <CheckBox Grid.Row="6" x:Name="ShowCodeCheck" Content="Show generated code in chat"
                  Margin="0,0,0,6" IsChecked="True"/>

        <!-- Logs / Report Issue -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" Margin="0,8,0,0">
            <Button Content="Open Log Folder" Padding="8,3" Click="OpenLogs_Click"
                    Background="Transparent" BorderBrush="#CCC" Cursor="Hand"/>
            <Button Content="Report Issue on GitHub" Padding="8,3" Margin="8,0,0,0"
                    Click="ReportIssue_Click" Background="Transparent" BorderBrush="#CCC" Cursor="Hand"/>
        </StackPanel>

        <!-- Copyright -->
        <TextBlock Grid.Row="8" Text="GIS Chat v1.0  |  © 2026 Zsolt Zoltán Fehér - GIS Expert  |  MIT License"
                   FontSize="9" Foreground="#AAA" VerticalAlignment="Bottom" Margin="0,0,0,8"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="80" Padding="4" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Save" Width="80" Padding="4" Background="#1565C0" Foreground="White" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
