<UserControl x:Class="GISChat.Views.ChatDockPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:GISChat.Views"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="350">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>

        <!-- User message style -->
        <DataTemplate x:Key="UserMessageTemplate">
            <Border Background="#E3F2FD" CornerRadius="8" Padding="10" Margin="40,4,8,4"
                    HorizontalAlignment="Right">
                <TextBox Text="{Binding Text, Mode=OneWay}" TextWrapping="Wrap" Foreground="#1A1A1A"
         IsReadOnly="True" Background="Transparent" BorderThickness="0" Padding="0"/>
            </Border>
        </DataTemplate>

        <!-- Assistant message style -->
        <DataTemplate x:Key="AssistantMessageTemplate">
            <StackPanel Margin="8,4,40,4">
                <Border x:Name="MsgBorder" Background="#F5F5F5" CornerRadius="8" Padding="10">
                    <StackPanel>
                        <Grid>
                            <TextBox Text="{Binding Text, Mode=OneWay}" TextWrapping="Wrap" Foreground="#1A1A1A"
                                     IsReadOnly="True" Background="Transparent" BorderThickness="0" Padding="0"/>
                            <Button x:Name="CopyBtn" Content="Copy" HorizontalAlignment="Right" VerticalAlignment="Top"
                                    FontSize="10" Padding="4,1" Cursor="Hand" Opacity="0"
                                    Background="#E0E0E0" Foreground="#616161" BorderThickness="0"
                                    Click="CopyMessage_Click" Tag="{Binding}"/>
                        </Grid>

                        <!-- Code block (if any) -->
                        <Border Background="#1E1E1E" CornerRadius="4" Padding="8" Margin="0,6,0,0"
                                Visibility="{Binding HasCode, Converter={StaticResource BoolToVisConverter}}">
                            <TextBox Text="{Binding CodeBlock, Mode=OneWay}" TextWrapping="Wrap"
                                     Foreground="#D4D4D4" FontFamily="Consolas" FontSize="11"
                                     IsReadOnly="True" Background="Transparent" BorderThickness="0" Padding="0"/>
                        </Border>

                        <!-- Execution result: success (green) -->
                        <Border Background="#E8F5E9" CornerRadius="4" Padding="8" Margin="0,6,0,0"
                                Visibility="{Binding IsResultSuccess, Converter={StaticResource BoolToVisConverter}}">
                            <TextBox Text="{Binding ExecutionResult, Mode=OneWay}" TextWrapping="Wrap"
                                     Foreground="#2E7D32" FontFamily="Consolas" FontSize="11"
                                     IsReadOnly="True" Background="Transparent" BorderThickness="0" Padding="0"/>
                        </Border>

                        <!-- Execution result: error (red) -->
                        <Border Background="#FFEBEE" CornerRadius="4" Padding="8" Margin="0,6,0,0"
                                Visibility="{Binding IsResultError, Converter={StaticResource BoolToVisConverter}}">
                            <TextBox Text="{Binding ExecutionResult, Mode=OneWay}" TextWrapping="Wrap"
                                     Foreground="#C62828" FontFamily="Consolas" FontSize="11"
                                     IsReadOnly="True" Background="Transparent" BorderThickness="0" Padding="0"/>
                        </Border>
                    </StackPanel>
                </Border>
                <StackPanel.Triggers>
                    <EventTrigger RoutedEvent="MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="CopyBtn" Storyboard.TargetProperty="Opacity"
                                                 To="1" Duration="0:0:0.15"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="CopyBtn" Storyboard.TargetProperty="Opacity"
                                                 To="0" Duration="0:0:0.15"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </StackPanel.Triggers>
            </StackPanel>
        </DataTemplate>

        <!-- System message style -->
        <DataTemplate x:Key="SystemMessageTemplate">
            <Border Background="#E3F2FD" CornerRadius="4" Padding="6" Margin="20,2,20,2"
                    HorizontalAlignment="Center">
                <TextBox Text="{Binding Text, Mode=OneWay}" TextWrapping="Wrap" Foreground="#1565C0"
                         FontSize="11" FontStyle="Italic" TextAlignment="Center"
                         IsReadOnly="True" Background="Transparent" BorderThickness="0" Padding="0"/>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1565C0" Padding="10,8">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="GIS Chat" Foreground="White" FontWeight="Bold" FontSize="14"/>
                    <!-- Connection status dot -->
                    <Ellipse Width="10" Height="10" Margin="8,0,0,0"
                             Fill="{Binding StatusColor}" VerticalAlignment="Center"
                             Stroke="White" StrokeThickness="1">
                        <Ellipse.ToolTip>
                            <ToolTip Content="{Binding StatusText}"/>
                        </Ellipse.ToolTip>
                    </Ellipse>
                </StackPanel>
                <Button Content="Clear" HorizontalAlignment="Right"
                        Command="{Binding ClearCommand}"
                        Background="Transparent" Foreground="White" BorderBrush="White"
                        Padding="8,2" Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- Chat messages -->
        <ListBox Grid.Row="1" x:Name="MessageList"
                 ItemsSource="{Binding Messages}"
                 Background="White" BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 SelectionMode="Single"
                 HorizontalContentAlignment="Stretch">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplateSelector>
                <views:MessageTemplateSelector
                    UserTemplate="{StaticResource UserMessageTemplate}"
                    AssistantTemplate="{StaticResource AssistantMessageTemplate}"
                    SystemTemplate="{StaticResource SystemMessageTemplate}"/>
            </ListBox.ItemTemplateSelector>
        </ListBox>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="#EEEEEE" Padding="8,4"
                Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisConverter}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Thinking..." FontSize="11" Foreground="#757575" FontStyle="Italic"/>
            </StackPanel>
        </Border>

        <!-- Input area -->
        <Border Grid.Row="3" Background="#FAFAFA" Padding="8" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" x:Name="InputBox"
                         Text="{Binding UserInput, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="False"
                         TextWrapping="Wrap"
                         MaxHeight="80"
                         VerticalScrollBarVisibility="Auto"
                         Padding="8,6"
                         FontSize="13"
                         BorderBrush="#BDBDBD"
                         BorderThickness="1"
                         KeyDown="InputBox_KeyDown">
                </TextBox>

                <Button Grid.Column="1" Content="Send"
                        Command="{Binding SendCommand}"
                        Margin="6,0,0,0" Padding="12,6"
                        Background="#1565C0" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        FontWeight="Bold"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
